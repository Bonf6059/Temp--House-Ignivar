    <!-- Ash Storm-->
    <WeatherDef>
        <defName>IgnivarAshStorm</defName>
        <label>Ash Storm</label>
        <description>An ash storm is rolling over the region, Any living thing not under a roof or suitably protected will slowly suffer from its effects.</description>
        <temperatureRange>-10~100</temperatureRange>
        <windSpeedFactor>2.5</windSpeedFactor>
        <accuracyMultiplier>0.7</accuracyMultiplier>
        <favorability>VeryBad</favorability>
        <perceivePriority>1</perceivePriority>
        <rainRate>0</rainRate>
        <moveSpeedMultiplier>0.7</moveSpeedMultiplier>
        <letterDef>ThreatBig</letterDef>
        <letterText>An ash storm is rolling over the region, Any living thing not under a roof or suitably protected will slowly suffer from its effects.</letterText>
        <letterLabel>Ash Storm</letterLabel>
        <durationRange>60000~240000</durationRange>
        <eventMakers>
            <li>
                <averageInterval>1200</averageInterval>
                <eventClass>WeatherEvent_LightningFlash</eventClass>
            </li>
