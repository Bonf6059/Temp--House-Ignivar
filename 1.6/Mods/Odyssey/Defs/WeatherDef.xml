<Defs>
    <!-- Ash Drift-->
    <WeatherDef>
        <defName>IgnivarAshDrift</defName>
        <label>Ash Drift</label>
        <description>A light layer of ash is settling over the region, it is not too dangerous, however any living thing not suitably protected will start to suffer from its effects after some time.</description>
        <temperatureRange>-10~100</temperatureRange>
        <windSpeedFactor>0.2</windSpeedFactor>
        <accuracyMultiplier>0.8</accuracyMultiplier>
        <favorability>Bad</favorability>
        <perceivePriority>1</perceivePriority>
        <moveSpeedMultiplier>0.9</moveSpeedMultiplier>
        <durationRange>30000~90000</durationRange>
        <overlayClasses>
            <li>WeatherOverlay_AshDrift</li>
        </overlayClasses>
        <commonalityRainfallFactor>
            <points>
                <li>(0, 0)</li>
                <li>(1300, 1)</li>
                <li>(4000, 2.0)</li>
            </points>
        </commonalityRainfallFactor>
        <skyColorsDay>
            <sky>(0.82,0.82,0.82)</sky>
            <shadow>(0.89,0.89,0.89)</shadow>
            <overlay>(0.84,0.84,0.84)</overlay>
            <saturation>0.83</saturation>
        </skyColorsDay>
        <skyColorsDusk>
            <sky>(0.83,0.83,0.83)</sky>
            <shadow>(0.89,0.89,0.89)</shadow>
            <overlay>(0.83,0.83,0.83)</overlay>
            <saturation>0.83</saturation>
        </skyColorsDusk>
        <skyColorsNightEdge>
            <sky>(0.81,0.81,0.81)</sky>
            <shadow>(0.88,0.88,0.88)</shadow>
            <overlay>(0.82,0.82,0.82)</overlay>
            <saturation>0.83</saturation>
        </skyColorsNightEdge>
        <skyColorsNightMid>
            <sky>(0.80,0.80,0.80)</sky>
            <shadow>(0.86,0.86,0.86)</shadow>
            <overlay>(0.81,0.81,0.81)</overlay>
            <saturation>0.83</saturation>
        </skyColorsNightMid>
    </WeatherDef>

