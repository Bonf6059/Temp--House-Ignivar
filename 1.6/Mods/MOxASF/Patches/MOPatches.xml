<!-- Add Raw Ashberries to Grape Barrel-->
<Patch>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="DankPyon_RusticGrapeBarrelEmpty"]/building/fixedStorageSettings/filter/thingDefs</xpath>
    <value>
      <li>Ignivar_RawAshberry</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[defName="ISA_Apparel_Padded_Surcoat"]/apparel/tags</xpath>
    <value>
      <li>IgnivarBlock</li>
    </value>
  </Operation>

</Patch>
