<Defs>
    <!-- Player Pawnkinds -->

    <PawnKindDef Name="IgnivarPlayerPawnKindBase" Abstract="True">
        <race>Human</race>
        <backstoryCategories>
            <li>Tribal</li>
        </backstoryCategories>
        <minGenerationAge>30</minGenerationAge>
        <maxGenerationAge>60</maxGenerationAge>
        <canBeSapper>true</canBeSapper>
        <isFighter>true</isFighter>
        <gearHealthRange>1~2</gearHealthRange>
        <apparelRequired>
            <li>DankPyon_Apparel_Braies</li>
            <!--  Middle (legs)  -->
            <li>DankPyon_Handwear_GlovesLeather</li>
            <!--  Middle (hands)  -->
            <li>DankPyon_Footwear_BootsLeather</li>
            <!--  Middle (feet)  -->
        </apparelRequired>
        <initialWillRange>2~4</initialWillRange>
        <initialResistanceRange>12~20</initialResistanceRange>
        <requiredWorkTags>
            <li>Violent</li>
        </requiredWorkTags>
        <chemicalAddictionChance>0.05</chemicalAddictionChance>
        <invNutrition>2.55</invNutrition>
        <invFoodDef>DankPyon_MealRations</invFoodDef>
    </PawnKindDef>


        <!-- Tier 0 Levy -->

    <PawnKindDef ParentName="IgnivarPlayerPawnKindBase">
        <defName>Ignivar_PlayerLevy</defName>
        <label>Levy</label>
        <defaultFactionType>Ignivar_PlayerOutpost</defaultFactionType>
        <combatPower>60</combatPower>
        <apparelMoney>400~600</apparelMoney>
        <apparelTags>
            <li>Ignivar_Light</li>
            <li>DankPyon_Peasant</li>
            <li>Ignivar_Worker</li>
        </apparelTags>
        <apparelDisallowTags>
            <li>IgnivarBlock</li>
        </apparelDisallowTags>
        <apparelRequired>
            <li>Ignivar_Hood</li>
            <li>Ignivar_Robe</li>
            <li>Ignivar_Toolbelt</li>
            <li>Ignivar_Scarf</li>
        </apparelRequired>
        <specificApparelRequirements>
             <!-- Toolbelt -->
            <li>
                <apparelLayer>Shell</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
            </li>
            <!-- Robe (Red) -->
             <li>
                <apparelLayer>OnSkin</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
                <color>(158, 81, 81)</color>
            </li>
             <!-- Scarf-->
            <li>
                <apparelLayer>DankPyon_ShellAttachment</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
            </li>
            <!-- Hood (Red) -->
            <li>
                <apparelLayer>Overhead</apparelLayer>
                <requiredTag>Ignivar_Worker</requiredTag>
                <color>(158, 81, 81)</color>
            </li>
        </specificApparelRequirements>
        <skills>
            <li>
                <skill>Melee</skill>
                <range>8~12</range>
            </li>
        </skills>
    </PawnKindDef>

    <!-- Tier 2 Knight -->

    <PawnKindDef ParentName="IgnivarPawnKindBase">
        <defName>Ignivar_PlayerKnight</defName>
        <label>Knight</label>
        <defaultFactionType>Ignivar_PlayerLone</defaultFactionType>
        <combatPower>110</combatPower>
        <itemQuality>Good</itemQuality>
        <factionLeader>true</factionLeader>
        <apparelMoney>1000~1200</apparelMoney>
        <apparelTags>
            <li>DankPyon_Knight</li>
            <li>Ignivar_Heavy</li>
            <li>DankPyon_Peasant</li>
        </apparelTags>
        <apparelRequired>
            <li>Ignivar_Plate</li>
            <li>Ignivar_Barbute</li>
        </apparelRequired>
        <specificApparelRequirements>
            <li>
                <apparelLayer>Shell</apparelLayer>
                <requiredTag>Ignivar_Heavy</requiredTag>
                <color>(153, 81, 81)</color>
            </li>
        </specificApparelRequirements>
        <weaponMoney>400~600</weaponMoney>
        <weaponTags>
            <li>Ignivar_Weapon_Heavy</li>
        </weaponTags>
        <skills>
            <li>
                <skill>Melee</skill>
                <range>8~16</range>
            </li>
        </skills>
    </PawnKindDef>

</Defs>