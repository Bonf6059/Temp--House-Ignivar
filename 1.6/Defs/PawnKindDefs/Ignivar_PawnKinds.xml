<Defs>
    <!-- Loyalist Pawnkinds -->

    <PawnKindDef Name="IgnivarPawnKindBase" Abstract="True">
        <race>Human</race>
        <defaultFactionType>Ignivar_Faction</defaultFactionType>
        <backstoryCategories>
            <li>Tribal</li>
        </backstoryCategories>
        <minGenerationAge>30</minGenerationAge>
        <maxGenerationAge>60</maxGenerationAge>
        <canBeSapper>true</canBeSapper>
        <isFighter>true</isFighter>
        <gearHealthRange>1~2</gearHealthRange>
        <apparelRequired>
            <!--<li>DankPyon_Apparel_Braies</li>-->
            <!--  Middle (legs)  -->
            <!--<li>DankPyon_Handwear_GlovesLeather</li>-->
            <!--  Middle (hands)  -->
            <!--<li>DankPyon_Footwear_BootsLeather</li>-->
            <!--  Middle (feet)  -->
        </apparelRequired>
        <initialWillRange>2~4</initialWillRange>
        <initialResistanceRange>12~20</initialResistanceRange>
        <requiredWorkTags>
            <li>Violent</li>
        </requiredWorkTags>
        <chemicalAddictionChance>0.05</chemicalAddictionChance>
        <invNutrition>2.55</invNutrition>
        <invFoodDef>ISA_DriedMeat</invFoodDef>
        <apparelIgnoreSeasons>true</apparelIgnoreSeasons>
    </PawnKindDef>


        <!-- Tier 0 Levy -->

    <PawnKindDef ParentName="IgnivarPawnKindBase">
        <defName>Ignivar_Levy</defName>
        <label>Levy</label>
        <combatPower>40</combatPower>
        <apparelMoney>400~600</apparelMoney>
        <apparelTags>
            <li>Ignivar_Light</li>
            <!--<li>DankPyon_Peasant</li>-->
            <li>Ignivar_Worker</li>
        </apparelTags>
        <apparelDisallowTags>
            <li>IgnivarBlock</li>
        </apparelDisallowTags>
        <apparelRequired>
            <li>Ignivar_Hood</li>
            <li>Ignivar_Robe</li>
            <li>Ignivar_Toolbelt</li>
            <li>Ignivar_Scarf</li>
        </apparelRequired>
        <specificApparelRequirements>
             <!-- Toolbelt -->
            <li>
                <apparelLayer>Shell</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
            </li>
            <!-- Robe (Red) -->
             <li>
                <apparelLayer>OnSkin</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
                <color>(158, 81, 81)</color>
            </li>
             <!-- Scarf -->
            <li>
                <apparelLayer>ISA_ShellAttachment</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
            </li>
            <!-- Hood (Red) -->
            <li>
                <apparelLayer>Overhead</apparelLayer>
                <requiredTag>Ignivar_Worker</requiredTag>
                <color>(158, 81, 81)</color>
            </li>
        </specificApparelRequirements>
        <weaponMoney>150~350</weaponMoney>
        <weaponTags>
            <li>Ignivar_Weapon_Worker</li>
            <li>ISA_Bludgeon</li>
            <li>MedievalMeleeBasic</li>
        </weaponTags>
        <skills>
            <li>
                <skill>Melee</skill>
                <range>4~10</range>
            </li>
        </skills>
    </PawnKindDef>


        <!-- Tier 1 Footman -->

    <PawnKindDef ParentName="IgnivarPawnKindBase">
        <defName>Ignivar_Footman</defName>
