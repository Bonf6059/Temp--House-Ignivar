            <!--<li>DankPyon_ShieldHeater</li>-->
        </apparelRequired>
        <apparelDisallowTags>
            <li>IgnivarBlock</li>
        </apparelDisallowTags>
        <specificApparelRequirements>
             <!-- Mail (Red) -->
            <li>
                <apparelLayer>Middle</apparelLayer>
                <requiredTag>Ignivar_Medium</requiredTag>
                <color>(158, 81, 81)</color>
            </li>
             <!-- Scarf -->
            <li>
                <apparelLayer>ISA_ShellAttachment</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
            </li>
            <!-- Headgear (Red) -->
            <li>
                <apparelLayer>Overhead</apparelLayer>
                <requiredTag>Ignivar_Light</requiredTag>
                <color>(158, 81, 81)</color>
            </li>
                        <!-- Shield (Red) -->
            <!--<li>
                <apparelLayer>VFEC_OuterShell</apparelLayer>
                <requiredTag>DankPyon_ShieldHeater</requiredTag>
                <color>(158, 81, 81)</color>
            </li>-->
        </specificApparelRequirements>
        <weaponMoney>250~600</weaponMoney>
        <weaponTags>
            <li>Ignivar_Weapon_Light</li>
            <li>Ignivar_Weapon_Medium</li>
        </weaponTags>
        <skills>
            <li>
                <skill>Melee</skill>
                <range>6~12</range>
            </li>
        </skills>
        <modExtensions>
            <li MayRequire="Owlchemist.GiddyUp" Class="GiddyUp.CustomMounts">
                <mountChance>20</mountChance>
                <possibleMounts>
                    <li MayRequire="Ludeon.Rimworld.Odyssey">
                        <key>GreatMonitorLizard</key>
                    </li>
                </possibleMounts>
            </li>
        </modExtensions>
    </PawnKindDef>


