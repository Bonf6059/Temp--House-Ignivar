<Defs>
	<ScenarioDef ParentName="ScenarioBase">
		<defName>Ignivar_OutpostStart</defName>
		<label>House Ignivar Flamesmith Outpost</label>
		<description>The three of you set out from the darkened skies of Mount Ignos many days ago. Running low on rations and patience you decide to call this new land your home. Though you are only armed with what you could carry and your wits, you have no doubt you will thrive in this new land, as the fires of Mount Ignos burn in your hearts.</description>
	<scenario>
		<summary>Three scions of House Ignivar</summary>
		<playerFaction>
			<def>PlayerFaction</def>
			<factionDef>Ignivar_PlayerOutpost</factionDef>
			</playerFaction>
			<parts>
				<li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
					<def>ConfigPage_ConfigureStartingPawns</def>
					<pawnChoiceCount>8</pawnChoiceCount>
					<pawnCount>3</pawnCount>
				</li>
				<li Class="ScenPart_PlayerPawnsArriveMethod">
					<def>PlayerPawnsArriveMethod</def>
				</li>
				<li Class="ScenPart_ScatterThingsAnywhere">
					<def>ScatterThingsAnywhere</def>
					<thingDef>DankPyon_BrokenCart</thingDef>
					<count>3</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Silver</thingDef>
					<count>400</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>DankPyon_DriedMeat</thingDef>
					<count>100</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Ignivar_AshberryWine</thingDef>
					<count>20</count>
					<quality>Good</quality>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>MedicineHerbal</thingDef>
					<count>30</count>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>DankPyon_IronIngot</thingDef>
					<count>200</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>WoodLog</thingDef>
					<count>400</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>DankPyon_ComponentBasic</thingDef>
					<count>15</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>DankPyon_MealRations</thingDef>
					<count>30</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Ignivar_Mail</thingDef>
					<stuff>DankPyon_IronIngot</stuff>
					<quality>Normal</quality>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Ignivar_Broadblade</thingDef>
					<stuff>Steel</stuff>
					<quality>Normal</quality>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Ignivar_ForgePike</thingDef>
					<stuff>DankPyon_IronIngot</stuff>
					<quality>Normal</quality>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Ignivar_Stavegonne</thingDef>
					<quality>Normal</quality>
				</li>
				<li Class="ScenPart_GameStartDialog">
					<def>GameStartDialog</def>
					<text>The three of you set out from the darkened skies of Mount Ignos many days ago. Running low on rations and patience you decide to call this new land your home. Though you are only armed with what you could carry and your wits, you have no doubt you will thrive in this new land, as the fires of Mount Ignos burn in your heart.</text>
					<textKey>GameStartDialog</textKey>
					<closeSound>GameStartSting</closeSound>
				</li>
			</parts>
		</scenario>
	</ScenarioDef>

</Defs>