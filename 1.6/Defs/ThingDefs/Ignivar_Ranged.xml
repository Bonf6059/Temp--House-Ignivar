<Defs>

    <!--  Stavegonne  -->

    <ThingDef ParentName="BaseMakeableGun">
        <defName>Ignivar_Stavegonne</defName>
        <label>Stavegonne</label>
        <description>A hand cannon of House Ignivar, forged by the flamesmiths, delivering fire and force with deliberate, unrelenting precision.</description>
        <graphicData>
            <texPath>Equipment/stavegonne</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1.17,1.17)</drawSize>
        </graphicData>
        <modExtensions>
            <li Class="VEF.Things.ThingDefExtension">
                <weaponDraftedDrawOffsets>
                    <north>
                        <drawOffset>(0.34,0,0.40)</drawOffset>
                        <angleOffset>-130</angleOffset>
                    </north>
                    <east>
                        <drawOffset>(0.15,0,0.40)</drawOffset>
                        <angleOffset>-120</angleOffset>
                    </east>
                    <south>
                        <drawOffset>(-0.34,0,0.40)</drawOffset>
                        <angleOffset>-150</angleOffset>
                    </south>
                    <west>
                        <drawOffset>(-0.15,0,0.40)</drawOffset>
                        <angleOffset>120</angleOffset>
                    </west>
                </weaponDraftedDrawOffsets>
            </li>
        </modExtensions>
        <equippedAngleOffset>40</equippedAngleOffset>
        <techLevel>Medieval</techLevel>
        <soundInteract>Interact_Rifle</soundInteract>
        <costList>
            <Steel>80</Steel>
            <Chemfuel>30</Chemfuel>
           <!-- <DankPyon_ComponentBasic>4</DankPyon_ComponentBasic>    -->
        </costList>
        <weaponTags>
            <li>Ignivar_Weapon_Gun</li>
        </weaponTags>
        <statBases>
            <WorkToMake>12000</WorkToMake>
            <Mass>4</Mass>
            <AccuracyTouch>0.87</AccuracyTouch>
            <AccuracyShort>0.83</AccuracyShort>
            <AccuracyMedium>0.73</AccuracyMedium>
            <AccuracyLong>0.61</AccuracyLong>
            <RangedWeapon_Cooldown>6</RangedWeapon_Cooldown>
        </statBases>
        <equippedStatOffsets>
            <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
        </equippedStatOffsets>
        <weaponClasses>
            <li>ShortShots</li>
        </weaponClasses>
        <recipeMaker Inherit="False">
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Smith</soundWorking>
            <recipeUsers>
                <li>ISA_AlchemyTable</li>
            </recipeUsers>
            <researchPrerequisites>
                <li>IgnivarArchives</li>
                <li>ISA_WarChemicals</li>
                <li>Smithing</li>
            </researchPrerequisites>
            <unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
            <skillRequirements>
                <Crafting>6</Crafting>
            </skillRequirements>
        </recipeMaker>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>Ignivar_Bullet_Handgonne</defaultProjectile>
                <warmupTime>1.35</warmupTime>
                <range>18</range>
                <soundCast>cindergonnefire</soundCast>
                <ticksBetweenBurstShots>0.5</ticksBetweenBurstShots>
                <soundCastTail>GunTail_Heavy</soundCastTail>
                <muzzleFlashScale>9</muzzleFlashScale>
                <targetParams>
                <canTargetLocations>true</canTargetLocations>
                </targetParams>
            </li>
        </verbs>
        <tools>
            <li>
                <label>stock</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>
    <ThingDef ParentName="BaseBullet">
        <defName>Ignivar_Bullet_Handgonne</defName>
        <label>handgonne shot</label>
        <graphicData>
            <texPath>Things/Projectile/Bullet_big</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile>
            <damageDef>Bullet</damageDef>
            <damageAmountBase>25</damageAmountBase>
            <stoppingPower>5</stoppingPower>
            <armorPenetrationBase>0.5</armorPenetrationBase>
            <speed>90</speed>
        </projectile>
    </ThingDef>


    <!--  Fyrlance  -->

    <ThingDef ParentName="BaseMakeableGun">
        <defName>Ignivar_Fyrlance</defName>
        <label>Fyrlance</label>
        <description>The pinnacle of the Flamesmiths designs, an engine of destruction that hurls burning tar in gouts of flame.</description>
        <graphicData>
            <texPath>Equipment/fyrlance</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1.3,1.3)</drawSize>
        </graphicData>
        <modExtensions>
            <li Class="VEF.Things.ThingDefExtension">
                <weaponDraftedDrawOffsets>
                    <north>
                        <drawOffset>(0.34,0,0.40)</drawOffset>
                        <angleOffset>-130</angleOffset>
                    </north>
                    <east>
                        <drawOffset>(0.15,0,0.40)</drawOffset>
                        <angleOffset>-120</angleOffset>
                    </east>
                    <south>
                        <drawOffset>(-0.34,0,0.40)</drawOffset>
                        <angleOffset>-150</angleOffset>
                    </south>
                    <west>
                        <drawOffset>(-0.15,0,0.40)</drawOffset>
                        <angleOffset>120</angleOffset>
                    </west>
                </weaponDraftedDrawOffsets>
            </li>
        </modExtensions>
        <equippedAngleOffset>40</equippedAngleOffset>
        <techLevel>Medieval</techLevel>
        <soundInteract>Interact_Rifle</soundInteract>
        <costList>
            <Steel>80</Steel>
            <Chemfuel>30</Chemfuel>
            <!--<DankPyon_ComponentBasic>4</DankPyon_ComponentBasic>-->
        </costList>
        <weaponTags>
            <li>Ignivar_Weapon_Fire</li>
        </weaponTags>
        <statBases>
            <WorkToMake>12000</WorkToMake>
            <Mass>4</Mass>
            <AccuracyTouch>0.87</AccuracyTouch>
            <AccuracyShort>0.83</AccuracyShort>
            <AccuracyMedium>0.73</AccuracyMedium>
            <AccuracyLong>0.61</AccuracyLong>
            <RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
        </statBases>
        <equippedStatOffsets>
            <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
        </equippedStatOffsets>
        <recipeMaker Inherit="False">
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Smith</soundWorking>
            <recipeUsers>
                <li>ISA_AlchemyTable</li>
            </recipeUsers>
            <researchPrerequisites>
                <li>IgnivarArchives</li>
                <li>IgnivarFyrlance</li>
            </researchPrerequisites>
            <unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
            <skillRequirements>
                <Crafting>10</Crafting>
            </skillRequirements>
        </recipeMaker>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>Bullet_Firelance</defaultProjectile>
                <warmupTime>4</warmupTime>
                <range>10</range>
                <forcedMissRadius>2</forcedMissRadius>
                <burstShotCount>3</burstShotCount>
                <soundCast>FireSpew_Resolve</soundCast>
                <soundCastTail>GunTail_Medium</soundCastTail>
                <muzzleFlashScale>14</muzzleFlashScale>
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
            </li>
        </verbs>
        <tools>
            <li>
                <label>stock</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>9</power>
                <cooldownTime>4</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>
    <ThingDef ParentName="BaseBullet">
        <defName>Bullet_Firelance</defName>
        <label>incendiary bolt</label>
        <graphicData>
            <texPath>Things/Projectile/LauncherShot</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>TransparentPostLight</shaderType>
            <color>(254,189,58)</color>
        </graphicData>
        <thingClass>Projectile_Explosive</thingClass>
        <projectile>
            <speed>40</speed>
            <soundExplode>Interact_BeatFire</soundExplode>
            <damageDef>Flame</damageDef>
            <!--  Use default damage from explosion def  -->
            <explosionRadius>1</explosionRadius>
            <preExplosionSpawnThingDef>Filth_Fuel</preExplosionSpawnThingDef>
            <preExplosionSpawnChance>0.6</preExplosionSpawnChance>
            <ai_IsIncendiary>true</ai_IsIncendiary>
            <arcHeightFactor>0.2</arcHeightFactor>
            <shadowSize>0</shadowSize>
        </projectile>
    </ThingDef>

    <!--  Fyrpot  -->
    <ThingDef ParentName="BaseMakeableGrenade">
        <defName>Ignivar_Fyrpot</defName>
        <label>Ignivar Fyrpot</label>
        <description>Forged in Ignivar forges, the Fyrpot bursts into life on impact, sending gouts of flame to consume all in its path.</description>
        <possessionCount>1</possessionCount>
        <researchPrerequisites>
            <li>IgnivarArchives</li>
            <li>ISA_WarChemicals</li>
        </researchPrerequisites>
        <tickerType>Normal</tickerType>
        <graphicData>
            <texPath>Projectile/Fyrpot</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <uiIconScale>1.3</uiIconScale>
        <soundInteract>Interact_MolotovCocktail</soundInteract>
        <techLevel>Medieval</techLevel>
        <statBases>
            <Mass>1</Mass>
            <RangedWeapon_Cooldown>2.66</RangedWeapon_Cooldown>
            <WorkToMake>6000</WorkToMake>
        </statBases>
        <costList>
            <Cloth>25</Cloth>
            <Chemfuel>80</Chemfuel>
        </costList>
        <weaponTags>
            <li>Ignivar_Weapon_Grenade</li>
        </weaponTags>
        <thingCategories>
            <li>Grenades</li>
        </thingCategories>
        <verbs>
            <li>
                <label>throw fyrpot</label>
                <verbClass>Verb_LaunchProjectile</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <range>12.9</range>
                <forcedMissRadius>1.9</forcedMissRadius>
                <warmupTime>1.5</warmupTime>
                <noiseRadius>4</noiseRadius>
                <soundCast>ThrowMolotovCocktail</soundCast>
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
                <defaultProjectile>Proj_GrenadeFyrpot</defaultProjectile>
                <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
            </li>
        </verbs>
        <comps>
            <li Class="CompProperties_Explosive">
                <explosiveRadius>1.66</explosiveRadius>
                <explosiveDamageType>Flame</explosiveDamageType>
                <requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
            </li>
        </comps>
        <rotateInShelves>false</rotateInShelves>
    </ThingDef>
    <ThingDef Name="BaseIncendiaryProjectile" ParentName="BaseGrenadeProjectile" Abstract="true">
        <projectile>
            <explosionRadius>1.1</explosionRadius>
            <damageDef>Flame</damageDef>
            <!--  Use default damage from explosion def  -->
            <preExplosionSpawnThingDef>Filth_Fuel</preExplosionSpawnThingDef>
            <ai_IsIncendiary>true</ai_IsIncendiary>
            <shadowSize>0.6</shadowSize>
            <screenShakeFactor>0.5</screenShakeFactor>
        </projectile>
    </ThingDef>
    <ThingDef ParentName="BaseIncendiaryProjectile">
        <defName>Proj_GrenadeFyrpot</defName>
        <label>fyrpot</label>
        <graphicData>
            <texPath>Projectile/Fyrpot</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
    </ThingDef>
</Defs>
