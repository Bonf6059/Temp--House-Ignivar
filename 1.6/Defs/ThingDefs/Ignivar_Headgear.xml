    <!-- Ignivar Barbute -->
    <ThingDef ParentName="IgnivarHelmetMakeableBase">
        <defName>Ignivar_Barbute</defName>
        <label>Ignivar Barbute</label>
        <description>Worn by the heavy infantry of House Ignivar, this visored barbute helmet provides strong, practical protection in battle, worn with an internal cloth mask to guard the wearer’s breath against ash in the harsh conditions of the Lava Fields.</description>
        <recipeMaker>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
            <skillRequirements>
                <Crafting>10</Crafting>
            </skillRequirements>
            <displayPriority>205</displayPriority>
            <researchPrerequisites>
                <li>PlateArmor</li>
                <li>IgnivarArchives</li>
            </researchPrerequisites>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/IgnivarBarbute/IgnivarBarbute</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <uiIconScale>1.4</uiIconScale>
        <statBases>
            <WorkToMake>16000</WorkToMake>
            <MaxHitPoints>140</MaxHitPoints>
            <Mass>2.75</Mass>
            <StuffEffectMultiplierArmor>0.65</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>0.6</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.5</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>4</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <ToxicEnvironmentResistance>0.4</ToxicEnvironmentResistance>
        </equippedStatOffsets>
        <stuffCategories>
            <li>Metallic</li>
        </stuffCategories>
        <costStuffCount>90</costStuffCount>
        <costList>
            <Cloth>30</Cloth>
        </costList>
        <apparel>
            <bodyPartGroups>
                <li>FullHead</li>
