<Defs>
<!-- Ignivar Robe -->
    <ThingDef ParentName="ApparelMakeableBase">
        <defName>Ignivar_Robe</defName>
        <label>Ignivar Robe</label>
        <description>Worn by the light footmen and levies of House Ignivar, this padded Robe offers flexible protection suited to fast movement and skirmishing in the harsh conditions of the magma wastes.</description>
        <possessionCount>1</possessionCount>
        <recipeMaker>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
            <researchPrerequisites>
                <li>DankPyon_ProtectiveClothing</li>
                <li>IgnivarArchives</li>
            </researchPrerequisites>
            <skillRequirements>
                <Crafting>4</Crafting>
            </skillRequirements>
            <displayPriority>250</displayPriority>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/IgnivarRobe/IgnivarRobe</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <costStuffCount>60</costStuffCount>
        <stuffCategories>
            <li>Fabric</li>
        </stuffCategories>
        <thingCategories>
            <li>ApparelArmor</li>
        </thingCategories>
        <statBases>
            <WorkToMake>10000</WorkToMake>
            <MaxHitPoints>160</MaxHitPoints>
            <Mass>4</Mass>
            <StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>1.6</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.5</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>5</EquipDelay>
        </statBases>
        <tradeTags>
            <li>Armor</li>
        </tradeTags>
        <apparel>
            <bodyPartGroups>
                <li>Torso</li>
                <li>Neck</li>
                <li>Shoulders</li>
                <li>Arms</li>
            </bodyPartGroups>
            <wornGraphicPath>Apparel/IgnivarRobe/IgnivarRobe</wornGraphicPath>
            <useWornGraphicMask>true</useWornGraphicMask>
            <layers>
                <li>OnSkin</li>
                <li>Middle</li>
            </layers>
            <canBeGeneratedToSatisfyWarmth>true</canBeGeneratedToSatisfyWarmth>
            <canBeGeneratedToSatisfyToxicEnvironmentResistance>true</canBeGeneratedToSatisfyToxicEnvironmentResistance>
            <tags>
                <li>Ignivar_Worker</li>
                <li>Ignivar_Light</li>
            </tags>
        </apparel>
        <colorGenerator Class="ColorGenerator_StandardApparel" />
    </ThingDef>

    <!-- Ignivar Scarf -->
    <ThingDef ParentName="ApparelMakeableBase">
        <defName>Ignivar_Scarf</defName>
        <label>Ignivar Ash Cloak</label>
        <description>A signature of House Ignivar, the ash cloak is worn by every man woman and child that braves the lava fields.</description>
        <possessionCount>1</possessionCount>
        <recipeMaker>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
            <researchPrerequisites>
                <li>DankPyon_ProtectiveClothing</li>
                <li>IgnivarArchives</li>
            </researchPrerequisites>
            <skillRequirements>
                <Crafting>4</Crafting>
            </skillRequirements>
            <displayPriority>250</displayPriority>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/IgnivarScarf/IgnivarScarf</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <costStuffCount>70</costStuffCount>
        <stuffCategories>
            <li>Fabric</li>
        </stuffCategories>
        <thingCategories>
            <li>Apparel</li>
        </thingCategories>
        <statBases>
            <WorkToMake>10000</WorkToMake>
            <MaxHitPoints>160</MaxHitPoints>
            <Mass>0.25</Mass>
            <StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>1.6</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.5</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>5</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <ToxicEnvironmentResistance>0.4</ToxicEnvironmentResistance>
        </equippedStatOffsets>
        <tradeTags>
            <li>Armor</li>
        </tradeTags>
        <apparel>
            <drawData>
				<dataNorth>
					<layer>90</layer>
				</dataNorth>
				<dataEast>
					<layer>40</layer>
				</dataEast>
				<dataSouth>
					<layer>40</layer>
				</dataSouth>
				<dataWest>
					<layer>40</layer>
				</dataWest>
			</drawData>
            <bodyPartGroups>
                <li>Neck</li>
            </bodyPartGroups>
            <wornGraphicPath>Apparel/IgnivarScarf/IgnivarScarf</wornGraphicPath>
            <layers>
                <li>DankPyon_ShellAttachment</li>
            </layers>
            <canBeGeneratedToSatisfyWarmth>true</canBeGeneratedToSatisfyWarmth>
            <canBeGeneratedToSatisfyToxicEnvironmentResistance>true</canBeGeneratedToSatisfyToxicEnvironmentResistance>
            <tags>
                <li>Ignivar_Worker</li>
                <li>Ignivar_Light</li>
                <li>Ignivar_Medium</li>
            </tags>
        </apparel>
    </ThingDef>

    <!-- Ignivar Toolbelt -->
    <ThingDef ParentName="ApparelMakeableBase">
        <defName>Ignivar_Toolbelt</defName>
        <label>Ignivar Toolbelt</label>
        <description>Worn by the flamesmiths and laborers of House Ignivar, the toolbelt carries the instruments needed to shape fire and stone with precision.</description>
        <possessionCount>1</possessionCount>
        <recipeMaker>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
            <researchPrerequisites>
                <li>DankPyon_Engineering</li>
                <li>IgnivarArchives</li>
            </researchPrerequisites>
            <skillRequirements>
                <Crafting>4</Crafting>
            </skillRequirements>
            <displayPriority>250</displayPriority>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/IgnivarToolbelt/IgnivarToolbelt</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <costList>
            <Steel>60</Steel>
            <DankPyon_ComponentBasic>4</DankPyon_ComponentBasic>
        </costList>
        <thingCategories>
            <li>Apparel</li>
        </thingCategories>
        <statBases>
            <WorkToMake>10000</WorkToMake>
            <MaxHitPoints>160</MaxHitPoints>
            <Mass>2</Mass>
            <StuffEffectMultiplierArmor>0.1</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>0.1</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.1</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>15</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <WorkSpeedGlobal>0.3</WorkSpeedGlobal>
        </equippedStatOffsets>
        <tradeTags>
            <li>Armor</li>
        </tradeTags>
        <apparel>
            <bodyPartGroups>
                <li>Torso</li>
            </bodyPartGroups>
            <wornGraphicPath>Apparel/IgnivarToolbelt/IgnivarToolbelt</wornGraphicPath>
            <layers>
                <li>Shell</li>
            </layers>
            <tags>
                <li>Ignivar_Worker</li>
                <li>Ignivar_Light</li>
            </tags>
        </apparel>
    </ThingDef>

    <!-- Ignivar Mail -->
    <ThingDef ParentName="ArmorSmithableBase">
        <defName>Ignivar_Mail</defName>
        <label>Ignivar Mail</label>
        <description>Sturdy mail, made for the infantry of House Ignivar, this Mail provides durable protection against both blade and heat in their ash-choked lands.</description>
        <possessionCount>1</possessionCount>
        <recipeMaker>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
            <researchPrerequisites>
                <li>DankPyon_ChainArmor</li>
                <li>IgnivarArchives</li>
            </researchPrerequisites>
            <skillRequirements>
                <Crafting>8</Crafting>
            </skillRequirements>
            <displayPriority>250</displayPriority>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/IgnivarMail/IgnivarMail</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <stuffCategories>
            <li>Metallic</li>
        </stuffCategories>
        <costStuffCount>140</costStuffCount>
        <costList>
            <Cloth>40</Cloth>
        </costList>
        <thingCategories>
            <li>ApparelArmor</li>
        </thingCategories>
        <statBases>
            <WorkToMake>32000</WorkToMake>
            <MaxHitPoints>290</MaxHitPoints>
            <Mass>15</Mass>
            <StuffEffectMultiplierArmor>0.7</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>1.6</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.5</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>15</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <MoveSpeed>-0.5</MoveSpeed>
        </equippedStatOffsets>
        <tradeTags>
            <li>Armor</li>
        </tradeTags>
        <apparel>
            <bodyPartGroups>
                <li>Torso</li>
                <li>Neck</li>
                <li>Shoulders</li>
                <li>Arms</li>
            </bodyPartGroups>
            <wornGraphicPath>Apparel/IgnivarMail/IgnivarMail</wornGraphicPath>
            <useWornGraphicMask>true</useWornGraphicMask>
            <layers>
                <li>OnSkin</li>
                <li>Middle</li>
                <li>Shell</li>
            </layers>
            <canBeGeneratedToSatisfyWarmth>true</canBeGeneratedToSatisfyWarmth>
            <canBeGeneratedToSatisfyToxicEnvironmentResistance>true</canBeGeneratedToSatisfyToxicEnvironmentResistance>
            <tags>
                <li>Ignivar_Medium</li>
            </tags>
        </apparel>
        <!-- ColorTwo Stuff -->
        <thingClass>ThingColor.ApparelColored</thingClass>
        <colorGenerator IsNull="True" />
        <modExtensions>
            <li Class="ThingColor.ThingExtension">
                <colorOneStuff>
                    <li>Fabric</li>
                </colorOneStuff>
                <colorTwoStuff>
                    <li>Metallic</li>
                </colorTwoStuff>
            </li>
        </modExtensions>
    </ThingDef>

    <!-- Ignivar Plate -->
    <ThingDef ParentName="ArmorSmithableBase">
        <defName>Ignivar_Plate</defName>
        <label>Ignivar Plate</label>
        <description>This heavy plate armour of House Ignivar is layered over ash-treated cloth and mail, its vented design dispersing heat and shielding the wearer from the choking, fire-scorched air of Ignos.</description>
        <possessionCount>1</possessionCount>
        <recipeMaker>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
            <researchPrerequisites>
                <li>PlateArmor</li>
                <li>IgnivarArchives</li>
            </researchPrerequisites>
            <skillRequirements>
                <Crafting>10</Crafting>
            </skillRequirements>
            <displayPriority>250</displayPriority>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/IgnivarPlate/IgnivarPlate</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <stuffCategories>
            <li>Metallic</li>
        </stuffCategories>
        <costStuffCount>160</costStuffCount>
        <costList>
            <Cloth>40</Cloth>
        </costList>
        <thingCategories>
            <li>ApparelArmor</li>
        </thingCategories>
        <statBases>
            <WorkToMake>38000</WorkToMake>
            <MaxHitPoints>290</MaxHitPoints>
            <Mass>15</Mass>
            <StuffEffectMultiplierArmor>0.8</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>1.6</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.5</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>15</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <MoveSpeed>-0.5</MoveSpeed>
        </equippedStatOffsets>
        <tradeTags>
            <li>Armor</li>
        </tradeTags>
        <apparel>
            <bodyPartGroups>
                <li>Torso</li>
                <li>Neck</li>
                <li>Shoulders</li>
                <li>Arms</li>
            </bodyPartGroups>
            <wornGraphicPath>Apparel/IgnivarPlate/IgnivarPlate</wornGraphicPath>
            <useWornGraphicMask>true</useWornGraphicMask>
            <layers>
                <li>OnSkin</li>
                <li>Middle</li>
                <li>Shell</li>
                <li>DankPyon_ShellAttachment</li>
            </layers>
            <tags>
                <li>Ignivar_Heavy</li>
            </tags>
        </apparel>
        <!-- ColorTwo Stuff -->
        <thingClass>ThingColor.ApparelColored</thingClass>
        <colorGenerator IsNull="True" />
        <modExtensions>
            <li Class="ThingColor.ThingExtension">
                <colorOneStuff>
                    <li>Fabric</li>
                </colorOneStuff>
                <colorTwoStuff>
                    <li>Metallic</li>
                </colorTwoStuff>
            </li>
        </modExtensions>
    </ThingDef>
</Defs>