                        <drawOffset>(0.34,0,0.50)</drawOffset>
                        <angleOffset>-143</angleOffset>
                    </north>
                    <east>
                        <drawOffset>(0.15,0,0.50)</drawOffset>
                        <angleOffset>-122</angleOffset>
                    </east>
                    <south>
                        <drawOffset>(-0.34,0,0.50)</drawOffset>
