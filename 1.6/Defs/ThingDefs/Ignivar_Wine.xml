<Defs>

    <ThingDef ParentName="ResourceBase">
        <defName>Ignivar_AshberryMust</defName>
        <label>Ashberry Must</label>
        <description>Crushed Ashberries. Needs to undergo fermentation in a rustic fermenting barrel in order to become wine.</description>
        <graphicData>
            <texPath>Items/AshberryMust</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <rotatable>false</rotatable>
        <stackLimit>25</stackLimit>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
        <statBases>
            <DeteriorationRate>1.0</DeteriorationRate>
            <MarketValue>2.5</MarketValue>
            <Mass>0.8</Mass>
            <Flammability>0.2</Flammability>
            <MaxHitPoints>60</MaxHitPoints>
        </statBases>
        <tickerType>Rare</tickerType>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>5</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="DrugBase">
        <defName>Ignivar_AshberryWine</defName>
        <label>Ashberry Wine</label>
        <description>Favoured by House Ignivar, Ashberry Wine is a dark, bitter vintage brewed from the hardy ashberries found in the magma wastes, valued for its rich flavour and warming strength.</description>
        <graphicData>
            <texPath>Items/AshberryWine</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <equippedAngleOffset>-150</equippedAngleOffset>
        <rotatable>false</rotatable>
        <stackLimit>10</stackLimit>
        <tools>
            <li>
                <label>bottle</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>neck</label>
                <capacities>
                    <li>Poke</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
        <statBases>
            <DeteriorationRate>0.5</DeteriorationRate>
            <MarketValue>20</MarketValue>
            <Mass>0.3</Mass>
            <Flammability>0.5</Flammability>
            <Nutrition>0.08</Nutrition>
        </statBases>
        <ingestible>
            <foodType>Fluid, Processed, Liquor</foodType>
            <joyKind>Chemical</joyKind>
            <joy>0.24</joy>
            <nurseable>true</nurseable>
            <drugCategory>Social</drugCategory>
            <ingestSound>Ingest_Beer</ingestSound>
            <ingestHoldOffsetStanding>
                <northDefault>
                    <offset>(0.18,0,0)</offset>
                </northDefault>
            </ingestHoldOffsetStanding>
            <ingestCommandString>Drink {0}</ingestCommandString>
            <ingestReportString>Drinking {0}.</ingestReportString>
            <chairSearchRadius>25</chairSearchRadius>
            <outcomeDoers>
                <li Class="IngestionOutcomeDoer_GiveHediff">
                    <hediffDef>AlcoholHigh</hediffDef>
                    <severity>0.22</severity>
                    <toleranceChemical>Alcohol</toleranceChemical>
                </li>
                <li Class="IngestionOutcomeDoer_GiveHediff">
                    <hediffDef>AlcoholTolerance</hediffDef>
                    <severity>0.023</severity>
                    <divideByBodySize>true</divideByBodySize>
                </li>
                <li Class="IngestionOutcomeDoer_GiveHediff">
                    <hediffDef>Ignivar_ToxResist</hediffDef>
                    <severity>0.2</severity>
                    <divideByBodySize>true</divideByBodySize>
                </li>
            </outcomeDoers>
        </ingestible>
        <equipmentType>Primary</equipmentType>
        <techLevel>Medieval</techLevel>
        <comps>
            <li Class="CompProperties_Drug">
                <chemical>Alcohol</chemical>
                <addictiveness>0.010</addictiveness>
                <minToleranceToAddict>0.25</minToleranceToAddict>
                <existingAddictionSeverityOffset>0.20</existingAddictionSeverityOffset>
                <needLevelOffset>1</needLevelOffset>
                <listOrder>10</listOrder>
            </li>
            <li>
                <compClass>CompEquippable</compClass>
            </li>
        </comps>
        <researchPrerequisites>
            <li>Brewing</li>
        </researchPrerequisites>
    </ThingDef>


</Defs>
